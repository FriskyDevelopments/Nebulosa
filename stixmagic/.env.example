# Environment Variables — Stix Magic

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/stixmagic

# Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Stripe secret key (required)
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret (required for webhook verification)
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for subscription plans (required)
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_PRO=price_...

# Telegram Stars prices per plan — number of stars for 30 days of access
# (optional, defaults: premium=75, pro=200)
STARS_PRICE_PREMIUM=75
STARS_PRICE_PRO=200

# Public base URL of the API server (used for Stripe callback URLs)
APP_BASE_URL=http://localhost:3000

# Port the API server listens on (optional, defaults to 3000)
PORT=3000
