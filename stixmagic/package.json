{
  "name": "stixmagic-bot",
  "version": "1.0.0",
  "description": "Stix Magic - Telegram sticker platform with Stripe subscriptions",
  "main": "dist/api/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only api/server.ts",
    "dev:bot": "ts-node-dev --respawn --transpile-only bot/bot.ts",
    "build": "tsc",
    "start": "node dist/api/server.js",
    "start:bot": "node dist/bot/bot.js",
    "db:generate": "prisma generate --schema=db/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=db/schema.prisma",
    "db:push": "prisma db push --schema=db/schema.prisma"
  },
  "keywords": ["telegram", "bot", "stripe", "stickers"],
  "author": "PupFr",
  "license": "MIT",
  "dependencies": {
    "grammy": "^1.21.1",
    "express": "^4.18.2",
    "@prisma/client": "^5.10.2",
    "stripe": "^14.18.0",
    "dotenv": "^16.4.5",
    "axios": "^1.6.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "prisma": "^5.10.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
