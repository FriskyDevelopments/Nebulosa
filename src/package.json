{
  "name": "stixmagic-platform",
  "version": "1.0.0",
  "description": "Stix Magic – modular monolith backend powering web and Telegram interfaces",
  "main": "api/server.js",
  "scripts": {
    "start": "node api/server.js",
    "dev": "node --watch api/server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --runInBand",
    "lint": "eslint . --ext .js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "worker:start": "node workers/index.js"
  },
  "keywords": [
    "stixmagic",
    "platform",
    "backend",
    "telegram",
    "express"
  ],
  "author": "Stix Magic",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-telegram-bot-api": "^0.66.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^5.14.0",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
