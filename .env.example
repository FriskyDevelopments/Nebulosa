# Stix Magic – environment variables

# Required: Telegram Bot API token (get from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Optional: HTTP server port (default: 3000)
PORT=3000

# Optional: Set to enable webhook mode (e.g. https://yourapp.railway.app)
# If not set, the bot runs in polling mode (useful for local dev)
WEBHOOK_URL=

# Subscription System — Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_PRO=price_...

# App
APP_BASE_URL=https://stixmagic.com
# Internal API base URL used by the Telegram bot to reach the server API
# Defaults to http://localhost:PORT when running in the same process
INTERNAL_API_URL=http://localhost:5000

# Admin debug endpoint (set to "false" to disable in production)
ADMIN_API_ENABLED=true

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname
