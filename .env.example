# Stix Magic – environment variables

# Required: Telegram Bot API token (get from @BotFather)
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Optional: HTTP server port (default: 3000)
PORT=3000

# Optional: Set to enable webhook mode (e.g. https://yourapp.railway.app)
# If not set, the bot runs in polling mode (useful for local dev)
WEBHOOK_URL=

# Zoom OAuth Credentials
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=
